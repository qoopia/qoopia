# ── Server ──────────────────────────────────────────────────
PORT=3000

# ── Database ────────────────────────────────────────────────
# QOOPIA_DATA_DIR=./data
# QOOPIA_DB_PATH=./data/qoopia.db

# ── Authentication ──────────────────────────────────────────
# JWT secret for OAuth tokens. Auto-generated if not set.
# QOOPIA_JWT_SECRET=

# Public URL (used for OAuth metadata, magic links, etc.)
# QOOPIA_PUBLIC_URL=https://your-domain.example.com

# ── Email (Magic Links) ────────────────────────────────────
# Resend API key for sending magic link emails
# RESEND_API_KEY=
# RESEND_FROM=Qoopia <noreply@your-domain.example.com>

# ── AI / Intelligence Layer (optional) ─────────────────────
# Anthropic API key for LLM-based entity matching
# QOOPIA_LLM_API_KEY=

# Voyage AI key for semantic search embeddings
# QOOPIA_VOYAGE_API_KEY=

# ── Workspace Files ────────────────────────────────────────
# Root directory for workspace file access via API
# QOOPIA_WORKSPACE_ROOT=./workspace

# ── Rate Limiting ──────────────────────────────────────────
# OAUTH_RATE_LIMIT=10

# ── Logging ────────────────────────────────────────────────
# LOG_LEVEL=info
